generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AllotmentSession {
  id            Int           @id @default(autoincrement())
  name          String
  status        SessionStatus @default(DRAFT)
  createdAt     DateTime      @default(now())
  algoMode      String        @default("preference_only")
  portalStatus  PortalStatus  @default(CLOSED)
  allotments    Allotment[]
  portalGroups  PortalGroup[]
  studentGroups StudentGroup[]
  students      Student[]

  @@map("allotment_sessions")
}

model Allotment {
  id        Int             @id @default(autoincrement())
  studentId Int
  roomId    Int?
  groupId   Int
  round     Int
  status    AllotmentStatus
  sessionId Int
  group     StudentGroup    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  room      Room?           @relation(fields: [roomId], references: [id])
  session   AllotmentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student   Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, sessionId, round])
  @@map("allotments")
}

model BlockRoomConfig {
  id            Int      @id @default(autoincrement())
  blockId       Int
  roomTypeId    Int
  roomsPerFloor Int
  block         Block    @relation(fields: [blockId], references: [id])
  roomType      RoomType @relation(fields: [roomTypeId], references: [id])

  @@unique([blockId, roomTypeId])
  @@map("block_room_configs")
}

model Block {
  id               Int              @id @default(autoincrement())
  number           Int              @unique
  gender           Gender
  floors           Int              @default(8)
  roomsPerFloor    Int              @default(30)
  roomConfigs       BlockRoomConfig[]
  pref1PortalGroups PortalGroup[]   @relation("PortalGroupPref1Block")
  pref2PortalGroups PortalGroup[]   @relation("PortalGroupPref2Block")
  rooms            Room[]
  pref1StudentGroups StudentGroup[] @relation("StudentGroupPref1Block")
  pref2StudentGroups StudentGroup[] @relation("StudentGroupPref2Block")

  @@map("blocks")
}

model GroupMember {
  id        Int          @id @default(autoincrement())
  groupId   Int
  studentId Int
  group     StudentGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  student   Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([groupId, studentId])
  @@map("group_members")
}

model PortalGroupMember {
  id            Int         @id @default(autoincrement())
  portalGroupId Int
  studentId     Int
  portalGroup   PortalGroup @relation(fields: [portalGroupId], references: [id], onDelete: Cascade)
  student       Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, portalGroupId])
  @@map("portal_group_members")
}

model PortalGroup {
  id              Int                 @id @default(autoincrement())
  sessionId       Int
  inviteCode      String              @unique
  leaderId        Int
  pref1BlockId    Int?
  pref1RoomTypeId Int?
  pref2BlockId    Int?
  pref2RoomTypeId Int?
  isSubmitted     Boolean             @default(false)
  createdAt       DateTime            @default(now())
  members         PortalGroupMember[]
  leader          Student             @relation(fields: [leaderId], references: [id], onDelete: Cascade)
  pref1Block      Block?              @relation("PortalGroupPref1Block", fields: [pref1BlockId], references: [id])
  pref1RoomType   RoomType?           @relation("PortalGroupPref1RoomType", fields: [pref1RoomTypeId], references: [id])
  pref2Block      Block?              @relation("PortalGroupPref2Block", fields: [pref2BlockId], references: [id])
  pref2RoomType   RoomType?           @relation("PortalGroupPref2RoomType", fields: [pref2RoomTypeId], references: [id])
  session         AllotmentSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("portal_groups")
}

model RoomType {
  id                 Int              @id @default(autoincrement())
  code               String           @unique
  name               String
  capacity           Int
  blockRoomConfigs   BlockRoomConfig[]
  pref1PortalGroups  PortalGroup[]    @relation("PortalGroupPref1RoomType")
  pref2PortalGroups  PortalGroup[]    @relation("PortalGroupPref2RoomType")
  rooms              Room[]
  pref1StudentGroups StudentGroup[]   @relation("StudentGroupPref1RoomType")
  pref2StudentGroups StudentGroup[]   @relation("StudentGroupPref2RoomType")

  @@map("room_types")
}

model Room {
  id           Int        @id @default(autoincrement())
  blockId      Int
  roomTypeId   Int
  floor        Int
  roomNumber   String
  occupiedBeds Int        @default(0)
  allotments   Allotment[]
  block        Block      @relation(fields: [blockId], references: [id])
  roomType     RoomType   @relation(fields: [roomTypeId], references: [id])

  @@unique([blockId, roomNumber])
  @@map("rooms")
}

model StudentGroup {
  id              Int              @id @default(autoincrement())
  avgCgpa         Float
  size            Int
  pref1BlockId    Int
  pref1RoomTypeId Int
  pref2BlockId    Int
  pref2RoomTypeId Int
  sessionId       Int
  allotments      Allotment[]
  members         GroupMember[]
  pref1Block      Block            @relation("StudentGroupPref1Block", fields: [pref1BlockId], references: [id])
  pref1RoomType   RoomType         @relation("StudentGroupPref1RoomType", fields: [pref1RoomTypeId], references: [id])
  pref2Block      Block            @relation("StudentGroupPref2Block", fields: [pref2BlockId], references: [id])
  pref2RoomType   RoomType         @relation("StudentGroupPref2RoomType", fields: [pref2RoomTypeId], references: [id])
  session         AllotmentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("student_groups")
}

model Student {
  id                     Int                 @id @default(autoincrement())
  regNo                  String
  name                   String
  gender                 Gender
  year                   Int
  department             String
  cgpa                   Float
  sessionId              Int
  pref1BlockNum          Int?
  pref1RoomTypeCode      String?
  pref2BlockNum          Int?
  pref2RoomTypeCode      String?
  password               String?
  source                 StudentSource       @default(CSV)
  allotments      Allotment[]
  groupMemberships GroupMember[]
  portalMemberships PortalGroupMember[]
  ledPortalGroups  PortalGroup[]
  session          AllotmentSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([regNo, sessionId])
  @@map("students")
}

model AllotmentAudit {
  id        Int      @id @default(autoincrement())
  studentId Int
  oldStatus String
  newStatus String
  changedAt DateTime @default(now())

  @@map("allotment_audits")
}

enum AllotmentStatus {
  ALLOTTED
  WAITLISTED
  OFF_CAMPUS
  DISALLOWED
}

enum Gender {
  MALE
  FEMALE
}

enum PortalStatus {
  CLOSED
  OPEN
  LOCKED
}

enum SessionStatus {
  DRAFT
  ROUND1_DONE
  ROUND2_DONE
  ROUND1_LOCKED
}

enum StudentSource {
  CSV
  PORTAL
}
